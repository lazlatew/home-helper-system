<h2>Login</h2>
<form method="post">
    <input name="username" placeholder="Username" /><br />
    <input name="password" placeholder="Password" type="password" /><br />
    <button type="submit">Login</button>
</form>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}